# MongoDB connection string
MONGODB_URI=mongodb://mongo:27017/chatapp

# Server port
PORT=3000

# JWT secret (generate a random string: openssl rand -hex 32)
JWT_SECRET=

# Google OAuth credentials (https://console.cloud.google.com/apis/credentials)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=/auth/google/callback

# GitHub OAuth credentials (https://github.com/settings/developers)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK_URL=/auth/github/callback

# Client URL (for CORS in development)
CLIENT_URL=http://localhost:5173

# Environment
NODE_ENV=development
